# Copy to .env and fill in

# Database
POSTGRES_USER=digifactory
POSTGRES_PASSWORD=changeme_secure_password_123
POSTGRES_DB=digifactory
DATABASE_URL=postgresql://digifactory:changeme_secure_password_123@db:5432/digifactory

# Redis
REDIS_URL=redis://redis:6379/0

# AI Services
OPENAI_API_KEY=sk-your-openai-key-here
REPLICATE_API_TOKEN=r8_your-rePLICATE-token

# Printify
PRINTIFY_SHOP_ID=your-shop-id
PRINTIFY_TOKEN=your-printify-token

# Etsy
ETSY_API_KEY=your-etsy-api-key
ETSY_SECRET=your-etsy-secret
ETSY_ACCESS_TOKEN=your-etsy-access-token
ETSY_REFRESH_TOKEN=your-etsy-refresh-token

# Fiverr (limited API)
FIVERR_ACCESS_TOKEN=your-fiverr-token

# Google Trends (uses pytrends, no API key needed but needs proxy for scale)
TRENDS_PROXY=

# App
SECRET_KEY=your-super-secret-jwt-key
ENVIRONMENT=development
